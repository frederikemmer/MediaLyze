{
  "schema_version": 1,
  "profile_version": 1,
  "id": "jellyfin-roku",
  "name": "Jellyfin (Roku)",
  "category": "player",
  "developer": "Jellyfin",
  "platforms": ["Roku OS"],
  "status": "official",
  "verified_by": "project documentation",
  "added": "2026-06-15",
  "last_modified": "2026-06-15",
  "server_fallback": "transcode",
  "video": {
    "mpeg4": {"mode": "direct"}, "h264": {"mode": "direct", "bit_depth": [8]},
    "hevc": {"mode": "conditional", "bit_depth": [8, 10], "conditions": [{"kind": "device_capability", "value": "4K Roku device"}]},
    "vp9": {"mode": "direct"}, "av1": {"mode": "conditional", "conditions": [{"kind": "device_capability", "value": "AV1-capable Roku"}]}
  },
  "audio": {
    "flac": {"mode": "direct"}, "mp3": {"mode": "direct"}, "aac": {"mode": "direct"},
    "ac3": {"mode": "direct"}, "eac3": {"mode": "direct"}, "vorbis": {"mode": "direct"},
    "dts": {"mode": "conditional", "conditions": [{"kind": "device_capability", "value": "DTS passthrough", "note": "DTS is supported through passthrough."}]},
    "opus": {"mode": "direct"}, "alac": {"mode": "direct_stream"}
  },
  "containers": {
    "mp4": {"mode": "direct"}, "mkv": {"mode": "direct"}, "webm": {"mode": "direct"},
    "ts": {"mode": "direct"}, "ogg": {"mode": "direct"}
  },
  "subtitles": {
    "srt": {"mode": "direct"}, "subrip": {"mode": "direct"}, "webvtt": {"mode": "direct_stream"},
    "ass": {"mode": "video_transcode"}, "ssa": {"mode": "video_transcode"},
    "dvd_subtitle": {"mode": "video_transcode"}, "hdmv_pgs_subtitle": {"mode": "video_transcode"}
  },
  "rules": [],
  "sources": [{"label": "Jellyfin codec support", "url": "https://jellyfin.org/docs/general/clients/codec-support/"}]
}
